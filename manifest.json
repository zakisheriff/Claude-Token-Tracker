{
  "manifest_version": 3,
  "name": "Claude Token Tracker",
  "version": "1.0.0",
  "description": "Native-style token, context, and usage tracking for Claude.ai. Built by The Atom.",
  "author": "The Atom",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Claude Token Tracker",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["inject.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
